{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./electron-dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "electron/**/*.ts",
    "src/lib/database.ts",
    "src/lib/seed-coa.ts",
    "src/lib/schema/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
