# Firebase Configuration
# احصل على هذه البيانات من Firebase Console > Project Settings

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Optional: For Analytics (if needed)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Sentry Error Reporting Configuration
# احصل على هذه البيانات من Sentry Dashboard > Project Settings

# Required: Sentry DSN (Data Source Name) - enables error reporting
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Optional: For source map uploads in production builds
# Get these from Sentry Dashboard > Settings > Auth Tokens
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
